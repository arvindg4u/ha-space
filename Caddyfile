{
    auto_https off
    admin off
}

:7860 {
    # Health check endpoint - HF Spaces health checker needs a quick 200
    handle /healthz {
        respond "OK" 200
    }

    # JupyterLab - preserve /lab prefix (Jupyter uses base_url=/lab)
    handle /lab* {
        reverse_proxy localhost:8888 {
            header_up Host {upstream_hostport}
        }
    }

    # Home Assistant - everything else
    handle {
        reverse_proxy localhost:8123 {
            header_up Host {upstream_hostport}
            header_up X-Forwarded-For {remote_host}
            header_up X-Forwarded-Proto {scheme}
        }
    }
}
