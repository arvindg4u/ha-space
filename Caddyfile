{
    auto_https off
    admin off
}

:7860 {
    # 1. Health check endpoint - immediate 200 for HF Spaces
    handle /healthz {
        respond "OK" 200
    }

    # 2. Landing page at root - served directly by Caddy (200 OK for health check)
    #    JS auto-redirects to HA onboarding or dashboard once ready
    handle / {
        root * /usr/share/caddy
        file_server
    }

    # 3. JupyterLab with base_url=/lab
    #    Match /lab exactly AND everything under /lab/
    @jupyter {
        path /lab /lab/*
    }
    handle @jupyter {
        reverse_proxy localhost:8888
    }

    # 4. Everything else → Home Assistant (API, frontend assets, onboarding, etc.)
    handle {
        reverse_proxy localhost:8123 {
            header_up X-Forwarded-For {remote_host}
            header_up X-Forwarded-Proto {scheme}
        }
    }
}
