#!/usr/bin/with-contenv bash
set -e
echo "[HA Space Setup] Running startup setup..."

# 1. ALWAYS copy/update the custom component from the image
#    Storage Bucket persists /config, but the image may have newer code
echo "[HA Space Setup] Installing/updating ha_space_updater component..."
mkdir -p /config/custom_components
cp -rf /usr/src/ha_space_updater /config/custom_components/
echo "[HA Space Setup] Component installed."

# 2. Detect Space URL from environment
SPACE_URL="${SPACE_URL:-}"
if [ -z "$SPACE_URL" ]; then
    # Try to detect from HF environment
    SPACE_ID="${SPACE_ID:-}"
    if [ -n "$SPACE_ID" ]; then
        SPACE_URL="https://${SPACE_ID//\//-}.hf.space"
    fi
fi

# 3. Configure HA for reverse proxy + JupyterLab sidebar panel + external URL
CONFIG_FILE="/config/configuration.yaml"

ensure_config_block() {
    local marker="$1"
    local block="$2"
    if [ -f "$CONFIG_FILE" ]; then
        if ! grep -qF "$marker" "$CONFIG_FILE"; then
            echo "$block" >> "$CONFIG_FILE"
            echo "[HA Space Setup] Added $marker section"
        fi
    else
        cat > "$CONFIG_FILE" << 'CONFEOF'
# Home Assistant configuration generated by HA Space
http:
  use_x_forwarded_for: true
  trusted_proxies:
    - 127.0.0.1
    - ::1

panel_iframe:
  jupyter:
    title: "JupyterLab"
    icon: "mdi:console"
    url: "/lab"
CONFEOF
        echo "[HA Space Setup] Created configuration.yaml"
    fi
}

ensure_config_block "use_x_forwarded_for" '
http:
  use_x_forwarded_for: true
  trusted_proxies:
    - 127.0.0.1
    - ::1
'

ensure_config_block "panel_iframe" '
panel_iframe:
  jupyter:
    title: "JupyterLab"
    icon: "mdi:console"
    url: "/lab"
'

# 4. If we detected the Space URL, ensure HA uses it for proper URL generation
if [ -n "$SPACE_URL" ] && [ -f "$CONFIG_FILE" ]; then
    if ! grep -q "external_url.*$SPACE_URL" "$CONFIG_FILE" 2>/dev/null; then
        # Remove any old external_url config to avoid duplicates
        sed -i '/^external_url:/d' "$CONFIG_FILE" 2>/dev/null || true
        echo "" >> "$CONFIG_FILE"
        echo "# Auto-detected Space URL" >> "$CONFIG_FILE"
        echo "external_url: \"$SPACE_URL\"" >> "$CONFIG_FILE"
        echo "[HA Space Setup] Set external_url to $SPACE_URL"
    fi
fi

echo "[HA Space Setup] Setup complete."
